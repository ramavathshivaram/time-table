<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Welcome to Time Table System</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      font-family: Helvetica, Arial, sans-serif;
      background: #f2f2f2;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0" style="padding: 50px 0">
      <tr>
        <td align="center">
          <table
            width="620"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #ffffff;
              border-radius: 14px;
              padding: 45px;
              border: 1px solid #e6e6e6;
              box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            "
          >
            <!-- Header -->
            <tr>
              <td align="center" style="padding-bottom: 25px">
                <!-- Avatar -->
                <img
                  src="<%= avatar %>"
                  alt="User Avatar"
                  width="80"
                  height="80"
                  style="
                    border-radius: 50%;
                    object-fit: cover;
                    border: 3px solid #eee;
                    margin-bottom: 10px;
                  "
                />

                <h1
                  style="
                    margin-top: 10px;
                    font-size: 28px;
                    color: #111;
                    letter-spacing: -0.5px;
                  "
                >
                  Welcome to Time Table
                </h1>
              </td>
            </tr>

            <!-- Greeting -->
            <tr>
              <td>
                <p
                  style="
                    font-size: 16px;
                    color: #222;
                    line-height: 1.7;
                    margin-bottom: 12px;
                  "
                >
                  Hello <b><%= userName %></b>,
                </p>

                <p style="font-size: 15px; color: #555; line-height: 1.7">
                  Your account has been successfully created for the
                  <b>Time Table Management System</b>.
                </p>

                <p style="font-size: 15px; color: #555; line-height: 1.7">
                  You can now access your timetable, track your schedule, and
                  stay updated with your academic activities.
                </p>
              </td>
            </tr>

            <!-- User Info Card -->
            <tr>
              <td style="padding-top: 30px">
                <table
                  width="100%"
                  style="
                    border: 1px solid #e8e8e8;
                    border-radius: 10px;
                    padding: 18px;
                    background: #fafafa;
                  "
                >
                  <tr>
                    <td>
                      <p style="margin: 6px 0; font-size: 14px; color: #333">
                        <b>Name</b><br />
                        <span style="color: #666"><%= userName %></span>
                      </p>

                      <p
                        style="
                          margin: 14px 0 6px 0;
                          font-size: 14px;
                          color: #333;
                        "
                      >
                        <b>Email</b><br />
                        <span style="color: #666"><%= email %></span>
                      </p>

                      <p
                        style="
                          margin: 14px 0 6px 0;
                          font-size: 14px;
                          color: #333;
                        "
                      >
                        <b>Avatar</b><br />
                        <span style="color: #666"><%= avatar %></span>
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Button -->
            <tr>
              <td align="center" style="padding-top: 35px">
                <a
                  href="http://localhost:5173/login"
                  style="
                    background: #111;
                    color: white;
                    padding: 14px 34px;
                    border-radius: 7px;
                    text-decoration: none;
                    font-size: 14px;
                    font-weight: 600;
                    letter-spacing: 0.3px;
                    display: inline-block;
                  "
                >
                  Access Dashboard
                </a>
              </td>
            </tr>

            <!-- Divider -->
            <tr>
              <td style="padding-top: 40px">
                <hr style="border: none; border-top: 1px solid #eee" />
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td align="center" style="padding-top: 20px">
                <p style="font-size: 13px; color: #777; margin-bottom: 6px">
                  If you did not register for this service, please ignore this
                  email.
                </p>

                <p style="font-size: 12px; color: #aaa">
                  © 2026 Time Table Management System
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
